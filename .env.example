# Neon PostgreSQL
# DATABASE_URL: アプリ実行時のコネクションプーリング用 (lib/prisma.ts の adapter-neon が使用)
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"
# DIRECT_URL: prisma migrate 用の直接接続 (prisma.config.ts が使用)
DIRECT_URL="postgresql://user:password@host/dbname?sslmode=require"

# Auth.js (next-auth v5)
AUTH_SECRET=""

# SSO プロバイダ (Azure AD / Google / GitHub)
AUTH_MICROSOFT_ENTRA_ID_ID=""
AUTH_MICROSOFT_ENTRA_ID_SECRET=""
AUTH_MICROSOFT_ENTRA_ID_ISSUER=""
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""

# AI生成(EDT002 経歴概要・自己PR)で使うAnthropic APIキー。
# 未設定の場合、AI生成ボタンはエラーになる(他機能には影響しない)。
ANTHROPIC_API_KEY=""

# GitHub OAuthアプリ(GitHub Settings > Developer settings > OAuth Apps で作成)
# - Homepage URL: http://localhost:3000
# - Authorization callback URL: http://localhost:3000/api/auth/callback/github
# 未設定の場合、ログイン画面のGitHubボタンは非活性表示になる
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""
